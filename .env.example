# --- Azure OpenAI (server-side only) ---
# Endpoint van je Azure OpenAI resource, bv. https://my-aoai.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# API key van je Azure OpenAI resource. Laat leeg om in mock-modus te draaien.
AZURE_OPENAI_API_KEY=
# Naam van je *deployment* (niet de modelnaam), bv. gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# API-versie. Min. 2024-06-01 voor logprobs/top_logprobs support.
AZURE_OPENAI_API_VERSION=2024-10-21
